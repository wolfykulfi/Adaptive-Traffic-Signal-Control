<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle types -->
    <vType id="car"   accel="2.6" decel="4.5" sigma="0.5" length="4.5" minGap="2.5" maxSpeed="13.89" speedDev="0.1" guiShape="passenger"  color="yellow"/>
    <vType id="truck" accel="1.0" decel="3.0" sigma="0.4" length="8.0" minGap="3.5" maxSpeed="11.11" speedDev="0.05" guiShape="delivery"  color="green"/>
    <vType id="moto"  accel="4.0" decel="6.0" sigma="0.6" length="2.2" minGap="1.5" maxSpeed="16.67" speedDev="0.15" guiShape="motorcycle" color="white"/>

    <!-- Routes -->
    <route id="N_S" edges="N2C C2S"/>
    <route id="N_E" edges="N2C C2E"/>
    <route id="N_W" edges="N2C C2W"/>

    <route id="S_N" edges="S2C C2N"/>
    <route id="S_W" edges="S2C C2W"/>
    <route id="S_E" edges="S2C C2E"/>

    <route id="E_W" edges="E2C C2W"/>
    <route id="E_N" edges="E2C C2N"/>
    <route id="E_S" edges="E2C C2S"/>

    <route id="W_E" edges="W2C C2E"/>
    <route id="W_S" edges="W2C C2S"/>
    <route id="W_N" edges="W2C C2N"/>

    <!--
        Traffic density per approach (vehicles/hour):
            North  →  HEAVY    ~480 veh/hr
            South  →  MEDIUM   ~280 veh/hr
            East   →  LIGHT    ~160 veh/hr
            West   →  HEAVIEST ~560 veh/hr  (commercial zone, trucks)

        departLane="random" spreads vehicles across lanes naturally.
        probability attribute = Poisson arrivals (random spacing).
    -->

    <!-- NORTH — Heavy -->
    <flow id="N_S_car"   route="N_S" type="car"   begin="0" end="3600" probability="0.110" departLane="random" departSpeed="max"/>
    <flow id="N_E_car"   route="N_E" type="car"   begin="0" end="3600" probability="0.030" departLane="random" departSpeed="max"/>
    <flow id="N_W_car"   route="N_W" type="car"   begin="0" end="3600" probability="0.050" departLane="random" departSpeed="max"/>
    <flow id="N_S_moto"  route="N_S" type="moto"  begin="0" end="3600" probability="0.010" departLane="random" departSpeed="max"/>

    <!-- SOUTH — Medium -->
    <flow id="S_N_car"   route="S_N" type="car"   begin="0" end="3600" probability="0.060" departLane="random" departSpeed="max"/>
    <flow id="S_W_car"   route="S_W" type="car"   begin="0" end="3600" probability="0.015" departLane="random" departSpeed="max"/>
    <flow id="S_E_car"   route="S_E" type="car"   begin="0" end="3600" probability="0.025" departLane="random" departSpeed="max"/>
    <flow id="S_N_moto"  route="S_N" type="moto"  begin="0" end="3600" probability="0.008" departLane="random" departSpeed="max"/>

    <!-- EAST — Light -->
    <flow id="E_W_car"   route="E_W" type="car"   begin="0" end="3600" probability="0.033" departLane="random" departSpeed="max"/>
    <flow id="E_N_car"   route="E_N" type="car"   begin="0" end="3600" probability="0.008" departLane="random" departSpeed="max"/>
    <flow id="E_S_car"   route="E_S" type="car"   begin="0" end="3600" probability="0.011" departLane="random" departSpeed="max"/>

    <!-- WEST — Heaviest (commercial, lots of trucks) -->
    <flow id="W_E_car"   route="W_E" type="car"   begin="0" end="3600" probability="0.120" departLane="random" departSpeed="max"/>
    <flow id="W_S_car"   route="W_S" type="car"   begin="0" end="3600" probability="0.030" departLane="random" departSpeed="max"/>
    <flow id="W_N_car"   route="W_N" type="car"   begin="0" end="3600" probability="0.050" departLane="random" departSpeed="max"/>
    <flow id="W_E_truck" route="W_E" type="truck" begin="0" end="3600" probability="0.025" departLane="random" departSpeed="0"/>
    <flow id="W_S_truck" route="W_S" type="truck" begin="0" end="3600" probability="0.008" departLane="random" departSpeed="0"/>
    <flow id="W_E_moto"  route="W_E" type="moto"  begin="0" end="3600" probability="0.012" departLane="random" departSpeed="max"/>

</routes>
